@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Task9 User Panel</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <a class="brand" asp-controller="Home" asp-action="Index">User Panel</a>
        <nav>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                @if (User.IsInRole(UserRoles.Admin))
                {
                    <a asp-controller="Admin" asp-action="Index">Admin</a>
                }
                <span class="signed-in">@User.FindFirstValue(ClaimTypes.Email)</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                    <button type="submit">Log out</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login">Log in</a>
                <a asp-controller="Account" asp-action="Register">Register</a>
            }
        </nav>
    </header>

    <main class="page">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
